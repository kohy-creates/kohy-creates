---
const {
	text = "Button",
	href = "#",
	width = "300px",
	height = "45px",
	target = "_self",
	maxWidth = "100%",
	icon = "",
} = Astro.props;
---

<a
	class="mc-button"
	href={href}
	target={target}
	style={`width: ${width}; height: ${height}; max-width: ${maxWidth}`}
>
	<div class="title">
		{
			icon && (
				<span><img src=`/icons/${icon}.png` style="height: 30px; padding-right: 10px;" /> </span>
			)
		}{text}
	</div>
</a>

<style>
	@font-face {
		font-family: MinecraftSeven;
		src: url("/font/Minecraft-Seven-2.ttf") format("truetype");
	}

	.mc-button {
		display: inline-block;
		cursor: pointer;
		text-decoration: none;
		background: white url("https://i.ibb.co/rb2TWXL/bgbtn.png") center;
		border: 2px solid #000;
		image-rendering: pixelated;
		user-select: none;
		overflow: hidden;
		font-family: MinecraftSeven !important;
		text-align: center;
		font-size: 1rem !important;
		letter-spacing: 0.5px;
		line-height: 1;
	}

	.mc-button:active {
		transform: translateY(2px);
	}

	.mc-button:hover .title {
		border: 2px solid white;
	}

	/* click */
	.mc-button:active .title {
		box-shadow:
			inset -2px -4px #0004,
			inset 2px 2px #fff5;
	}

	/* text layer */
	.title {
		height: 100%;
		width: 100%;

		display: flex;
		align-items: center;
		justify-content: center;

		color: white;
		text-shadow: 2px 2px #000a;

		box-shadow:
			inset -2px -4px #0006,
			inset 2px 2px #fff7;

		font-smooth: never;
		-webkit-font-smoothing: none;
	}

	img.title {
		font-smooth: initial !important;
	}
</style>
